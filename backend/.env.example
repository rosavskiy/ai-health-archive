# ─── App ──────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_64_CHAR_KEY

# ─── Database (PostgreSQL — РФ контур) ────────────────────────────────────
DATABASE_URL=postgresql://healthsafe:healthsafe@db:5432/healthsafe

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Yandex Object Storage (S3) ──────────────────────────────────────────
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=YOUR_YANDEX_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_YANDEX_S3_SECRET_KEY
S3_BUCKET=healthsafe-docs
# AES-256 ключ (base64 от 32 байт): python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
S3_ENCRYPTION_KEY=REPLACE_WITH_BASE64_AES256_KEY

# ─── Yandex Vision OCR ───────────────────────────────────────────────────
YANDEX_VISION_API_KEY=YOUR_YANDEX_VISION_API_KEY
YANDEX_FOLDER_ID=YOUR_YANDEX_FOLDER_ID

# ─── OpenAI (только для анонимизированного текста!) ──────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o

# ─── IMAP Email Sync (при необходимости) ─────────────────────────────────
IMAP_HOST=imap.yandex.ru
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────
# Сгенерировать: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key,v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@healthsafe.ru

# ─── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://healthsafe.ru"]
